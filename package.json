{
  "name": "blackwall-mcp",
  "version": "1.2.0",
  "mcpName": "com.blackwalltier/blackwall",
  "description": "BLACK_WALL MCP server — a pre-action risk check your AI agent calls before any irreversible action (send email, move money, run SQL, delete data).",
  "type": "module",
  "bin": {
    "blackwall-mcp": "index.mjs"
  },
  "exports": {
    ".": "./index.mjs",
    "./lib/forecast": "./lib/forecast.mjs",
    "./lib/observe": "./lib/observe.mjs",
    "./lib/gate": "./lib/gate.mjs",
    "./lib": "./lib/index.mjs"
  },
  "files": [
    "index.mjs",
    "lib",
    "README.md"
  ],
  "scripts": {
    "start": "node index.mjs",
    "test": "node --test",
    "prepare": "git config core.hooksPath .githooks",
    "secrets:scan": "gitleaks git --no-banner --config .gitleaks.toml"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "guardrails",
    "ai-safety",
    "blackwall"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18"
  }
}
